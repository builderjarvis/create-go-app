package example

import (
	"context"

	"github.com/saucesteals/fhttp"
)

type exampleRequest struct {
	Example string `json:"example"`
}

type exampleResponse struct {
	ResponseBytes []byte
}

// Example demonstrates a POST request with JSON payload and raw byte response.
func (s *Service) Example(ctx context.Context) (*exampleResponse, error) {
	payload := exampleRequest{
		Example: "example",
	}

	var resp []byte
	if err := s.doRequest(ctx, http.MethodPost, "/path", payload, &resp); err != nil {
		return nil, err
	}

	return &exampleResponse{
		ResponseBytes: resp,
	}, nil
}
