// Package main is the entry point for the {{.ProjectName}} application.
package main

import (
	"context"
	"log/slog"
	"os"
	"os/signal"
	"syscall"
{{- if or (has "postgres") (has "httpclient")}}
	"fmt"
{{- end}}

	"{{.ModulePath}}/pkg/env"
	"{{.ModulePath}}/pkg/log"
{{- if has "postgres"}}
	"{{.ModulePath}}/pkg/db"
{{- end}}
{{- if has "httpclient"}}
	"{{.ModulePath}}/pkg/client"
{{- end}}
)

func main() {
	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	config, err := env.New()
	if err != nil {
		slog.ErrorContext(ctx, "failed to load config", "error", err)
		os.Exit(1)
	}

	slog.SetDefault(log.New(config.LogLevel))

	if err := run(ctx, config); err != nil {
		slog.ErrorContext(ctx, "failed to run", "error", err)
		os.Exit(1)
	}
}

func run(ctx context.Context, config *env.Config) error {
	slog.InfoContext(ctx, "{{.ProjectName}} started")
{{- if has "postgres"}}

	database, err := db.New(ctx, config.DatabaseURL)
	if err != nil {
		return fmt.Errorf("create database: %w", err)
	}
	defer database.Close()
{{- end}}
{{- if has "httpclient"}}

	// Example: create an HTTP client with no proxy.
	httpClient, err := client.New(nil)
	if err != nil {
		return fmt.Errorf("create http client: %w", err)
	}

	slog.InfoContext(ctx, "http client ready", "user_agent", httpClient.UserAgent())
{{- end}}
{{- if not (has "postgres")}}
	_ = config
{{- end}}
	_ = ctx

	// TODO: Add your application logic here.

	return nil
}
